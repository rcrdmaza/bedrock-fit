# Postgres connection string. On Railway, point this at the bound postgres
# reference so rotations are automatic.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Password for the single admin login at /admin/login. Pick something long
# and random — there is no rate limit or account lockout.
ADMIN_PASSWORD=

# HMAC secret used to sign the admin session cookie. Any sufficiently long
# random string. Rotating this invalidates all existing admin sessions.
SESSION_SECRET=

# --- Optional: error monitoring (Sentry) ---
# If set, server and client runtime errors flow to this project. Leave blank
# in dev — the SDK init is no-op without a DSN.
SENTRY_DSN=
# Mirror of SENTRY_DSN, inlined into the client bundle at build time. Keep
# in sync with SENTRY_DSN; Next only exposes NEXT_PUBLIC_* to the browser.
NEXT_PUBLIC_SENTRY_DSN=
# Only needed if you want source-map upload on deploy. Set all three together
# with a Sentry internal integration auth token in CI.
SENTRY_ORG=
SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=
